# =============================================================================
# Vibe MVP Starter — environment variables
# =============================================================================
# Copy this file to .env.local and fill in only what you need.
# Never commit .env.local — it's gitignored.
# =============================================================================

# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# All off by default. Turn on only what your product needs.
# ------------------------------------------------------------

FEATURE_AUTH=false
FEATURE_EMAIL_VERIFY=false
FEATURE_AI=false
FEATURE_CHATBOT=false
FEATURE_ADMIN=false
FEATURE_DELIVERABLES=false
FEATURE_ANALYTICS=false

# ------------------------------------------------------------
# AUTH (required when FEATURE_AUTH=true)
# ------------------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET=
# At least one provider below:
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ------------------------------------------------------------
# EMAIL (required for magic-link auth + verification + any transactional mail)
# ------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="App <onboarding@resend.dev>"

# ------------------------------------------------------------
# AI (required when FEATURE_AI=true)
# ------------------------------------------------------------
OPENAI_API_KEY=
# Optional: override the default model
# OPENAI_MODEL=gpt-5-nano

# ------------------------------------------------------------
# ADMIN DASHBOARD (required when FEATURE_ADMIN=true)
# ------------------------------------------------------------
# Generate: openssl rand -base64 32
ADMIN_PASSWORD=

# ------------------------------------------------------------
# DATABASE (required for sessions, email verification, admin KPIs)
# ------------------------------------------------------------
# Local dev default: file:./local.db (SQLite)
# Prod: Turso (libsql) — get URL + token from https://turso.tech
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# ------------------------------------------------------------
# DEPLOY (set by sub-skill 11 when you push to Vercel)
# ------------------------------------------------------------
VERCEL_TOKEN=
